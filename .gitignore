# ==============================================================
# 编译产物 (Build Outputs)
# ==============================================================
Debug/
Release/
*.out
*.obj
*.o
*.d
*.map
*_linkInfo.xml

# CCS 自动生成的 makefile
ccsObjs.opt
makefile
objects.mk
sources.mk
subdir_rules.mk
subdir_vars.mk

# ==============================================================
# 编译中间文件
# ==============================================================
*.ilk
*.pdb
*.exp
*.lib  (但保留 lib/ 目录下的实际库文件，这个规则需要手动处理)

# ==============================================================
# TI CCS 相关
# ==============================================================
.ccsproject.bak
.cproject.bak
.project.bak
.settings/.prefs.bak
*.ccxml.bak

# Flash 编程相关
*.txt  (排除生成的 hex/bin 转换文件，如有需要请手动 git add)
*.hex
*.bin

# ==============================================================
# IDE / 编辑器
# ==============================================================
# .vscode/   ← 如果需要团队共享 VSCode 配置，请注释掉这行
.idea/
*.swp
*.swo
*~

# ==============================================================
# 操作系统
# ==============================================================
Thumbs.db
.DS_Store
Desktop.ini

# ==============================================================
# 临时文件
# ==============================================================
*.tmp
*.bak
*.log
